{
  "extraKnownMarketplaces": {
    "fractary-core": {
      "source": {
        "source": "github",
        "repo": "fractary/core"
      }
    },
    "fractary-codex": {
      "source": {
        "source": "github",
        "repo": "fractary/codex"
      }
    },
    "fractary-faber": {
      "source": {
        "source": "github",
        "repo": "fractary/faber"
      }
    },
    "fractary-faber-cloud": {
      "source": {
        "source": "github",
        "repo": "fractary/faber-cloud"
      }
    },
    "fractary-faber-code": {
      "source": {
        "source": "github",
        "repo": "fractary/faber-code"
      }
    }
  },
  "enabledPlugins": {
    "fractary-core@fractary-core": true,
    "fractary-repo@fractary-core": true,
    "fractary-work@fractary-core": true,
    "fractary-docs@fractary-core": true,
    "fractary-logs@fractary-core": true,
    "fractary-file@fractary-core": true,
    "fractary-codex@fractary-codex": true,
    "fractary-faber@fractary-faber": true,
    "fractary-faber-cloud@fractary-faber-cloud": true,
    "fractary-faber-code@fractary-faber-code": true
  },
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(true)",
      "Bash(npm install:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(rm:*)",
      "Bash(aws:*)",
      "Bash(terraform:*)",
      "Bash(source:*)",
      "Bash(grep:*)",
      "Bash(touch:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(gh:*)",
      "Bash(sleep:*)",
      "Bash(basename:*)",
      "Bash(pwd)",
      "Bash(~/dotfiles.jamnaytac.com/scripts/claude/claude-sync.sh:*)",
      "Bash(./scripts/claude/claude-sync.sh:*)",
      "Bash(rsync:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(./secrets/**)",
      "Read(./.ssh/**)",
      "Read(./.aws/**)",
      "Read(./.config/**)",
      "Read(./.kube/**)"
    ],
    "bash": {
      "allow": [
        "awk",
        "cat",
        "echo",
        "find",
        "gh api",
        "gh app list",
        "gh app view",
        "gh auth login",
        "gh auth refresh",
        "gh auth status",
        "gh issue close",
        "gh issue comment",
        "gh issue create",
        "gh issue list",
        "gh issue view",
        "gh pr close",
        "gh pr comment",
        "gh pr create",
        "gh pr list",
        "gh pr review",
        "gh pr status",
        "gh pr view",
        "gh repo clone",
        "gh repo view",
        "gh secret list",
        "gh secret set",
        "gh workflow disable",
        "gh workflow enable",
        "gh workflow list",
        "gh workflow run",
        "gh workflow view",
        "git add",
        "git branch",
        "git checkout",
        "git commit",
        "git config",
        "git diff",
        "git fetch",
        "git for-each-ref",
        "git log",
        "git ls-remote",
        "git merge",
        "git pull",
        "git push",
        "git rebase",
        "git remote",
        "git reset",
        "git rev-parse",
        "git show",
        "git show-ref",
        "git stash",
        "git status",
        "git switch",
        "git tag",
        "grep",
        "head",
        "jq",
        "ls",
        "pwd",
        "sed",
        "sort",
        "tail",
        "uniq",
        "wc",
        "which"
      ],
      "requireApproval": [
        "git push --set-upstream origin main",
        "git push --set-upstream origin master",
        "git push --set-upstream origin production",
        "git push -u origin main",
        "git push -u origin master",
        "git push -u origin production",
        "git push origin main",
        "git push origin master",
        "git push origin production"
      ],
      "deny": [
        "> /dev/sd",
        "chmod 777",
        "chown",
        "curl | bash",
        "curl | sh",
        "dd if=",
        "format",
        "gh repo archive",
        "gh repo delete",
        "gh secret delete",
        "gh secret remove",
        "git clean -fdx",
        "git filter-branch",
        "git push --force origin main",
        "git push --force origin master",
        "git push --force origin production",
        "git push --force-with-lease origin main",
        "git push --force-with-lease origin master",
        "git push --force-with-lease origin production",
        "git push -f origin main",
        "git push -f origin master",
        "git push -f origin production",
        "git rebase --onto",
        "git reset --hard origin/main",
        "git reset --hard origin/master",
        "git reset --hard origin/production",
        "init",
        "kill -9",
        "mkfs",
        "pkill",
        "reboot",
        "rm -rf *",
        "rm -rf .",
        "rm -rf /",
        "rm -rf ~",
        "shutdown",
        "su",
        "sudo",
        "systemctl",
        "wget | bash",
        "wget | sh"
      ]
    }
  }
}
