{
  "name": "@corthos/corthography-sdk",
  "version": "0.1.6",
  "description": "TypeScript SDK for the Corthography Press API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corthosai/client.corthography.ai.git",
    "directory": "sdk/js"
  },
  "homepage": "https://github.com/corthosai/client.corthography.ai#readme",
  "bugs": "https://github.com/corthosai/client.corthography.ai/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
